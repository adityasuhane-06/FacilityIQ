# Database
POSTGRES_DB=ticketdb
POSTGRES_USER=ticketuser
POSTGRES_PASSWORD=ticketpass
DATABASE_URL=jdbc:postgresql://postgres:5432/ticketdb

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# JWT
JWT_SECRET=your-secret-key-change-in-production-min-256-bits
JWT_EXPIRATION_MS=86400000

# Server
BACKEND_PORT=8080
FRONTEND_PORT=5173
